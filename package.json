{
  "name": "wt-tactical-map",
  "version": "1.0.0",
  "description": "War Thunder Tactical Map Wrapper",
  "author": "Tjorven Liebe",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "make": "electron-forge make",
    "dist-win": "electron-forge make --platform=win32",
    "dist-mac": "electron-forge make --platform=darwin",
    "dist-linux": "electron-forge make --platform=linux",
    "dist-all": "npm run dist-win && npm run dist-mac && npm run dist-linux"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "electron": "^43.1.1"
  }
}
